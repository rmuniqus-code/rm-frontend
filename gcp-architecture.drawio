  <diagram id="rm-gcp-network-topology" name="Network Topology — VPC, Subnet, Private Service Access">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" value="Network Topology — rm-vpc (custom subnet mode, us-central1)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1A3E5C;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle2" value="Subnet range · Private Service Access peering · Direct VPC egress path · why no Cloud NAT is needed" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#5A6C7D;" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="1100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="internet" value="Internet&#xa;(0.0.0.0/0)&#xa;Zoho + Supabase reached directly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#757575;fontColor=#212121;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cloudrun-ext" value="Cloud Run Service Runtime&#xa;(Google-managed, OUTSIDE customer VPC)&#xa;Public HTTPS endpoint: www.unisource.uniqus.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#1A73E8;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;dashed=4;" vertex="1" parent="1">
          <mxGeometry x="480" y="200" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="vpc2" value="rm-vpc   (custom subnet mode, no default CIDR)" style="rounded=1;whiteSpace=wrap;html=1;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;strokeColor=#248814;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#248814;fontSize=14;fontStyle=1;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="300" width="1300" height="620" as="geometry" />
        </mxCell>
        <mxCell id="region-box" value="us-central1" style="rounded=1;whiteSpace=wrap;html=1;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;strokeColor=#147EBA;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;fontSize=12;fontStyle=1;dashed=1;" vertex="1" parent="vpc2">
          <mxGeometry x="40" y="50" width="1220" height="300" as="geometry" />
        </mxCell>
        <mxCell id="subnet-app-2" value="rm-subnet-app · 10.10.0.0/24 (us-central1)&#xa;Direct VPC egress attach point for Cloud Run" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#7AA116;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;dashed=0;" vertex="1" parent="region-box">
          <mxGeometry x="30" y="40" width="1160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="egress-detail" value="vpc-egress = private-ranges-only&#xa;Traffic to RFC1918 ranges (10.0.0.0/8 etc.) → routed inside VPC&#xa;All other traffic (Zoho, Supabase, public APIs) → goes straight to&#xa;the internet, bypassing the VPC entirely — this is why no Cloud&#xa;NAT / NAT Gateway equivalent is required, unlike the AWS design." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A73E8;fontColor=#1A73E8;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="subnet-app-2">
          <mxGeometry x="30" y="30" width="1100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="psa-range-2" value="rm-private-service-range · /24 (VPC peering, VPC_PEERING purpose)&#xa;Reserved via `gcloud compute addresses create` + `gcloud services vpc-peerings connect`" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#D45B07;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;dashed=0;" vertex="1" parent="region-box">
          <mxGeometry x="30" y="170" width="1160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="cloudsql-2" value="Cloud SQL PostgreSQL 16&#xa;rm-db-prod, db-f1-micro&#xa;--no-assign-ip (no public IP)&#xa;Only reachable via this&#xa;peered private-services range" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3334B9;fontColor=#3334B9;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="psa-range-2">
          <mxGeometry x="420" y="25" width="320" height="75" as="geometry" />
        </mxCell>
        <mxCell id="secretmgr-2" value="Secret Manager&#xa;rm-cloudrun-sa has&#xa;roles/secretmanager.secretAccessor&#xa;(no VPC path needed — API call,&#xa;not a network route)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="vpc2">
          <mxGeometry x="80" y="400" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="iam-note-2" value="IAM boundary&#xa;rm-cloudrun-sa: roles/cloudsql.client,&#xa;roles/secretmanager.secretAccessor, roles/logging.logWriter&#xa;jenkins-gcp-deploy: roles/artifactregistry.writer,&#xa;roles/run.developer, roles/iam.serviceAccountUser (on rm-cloudrun-sa)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B36B00;fontColor=#B36B00;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="vpc2">
          <mxGeometry x="420" y="400" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="compare-box" value="Compared to the approved AWS network design&#xa;&#xa;AWS: 6 subnets across 2 AZs (public / private-app / private-db),&#xa;   NAT Gateway required for all App Runner egress (~$32/mo)&#xa;GCP: 1 subnet + 1 peered private-services range, no NAT —&#xa;   Direct VPC egress with private-ranges-only splits traffic&#xa;   without needing a managed NAT device&#xa;&#xa;Trade-off: GCP&#39;s design has less built-in AZ redundancy at&#xa;launch (single-zone Cloud SQL, same as AWS&#39;s Single-AZ RDS&#xa;start) — regional HA is an equivalent later upgrade on both." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E6B800;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" vertex="1" parent="vpc2">
          <mxGeometry x="900" y="400" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="e-internet-cloudrun" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1A73E8;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="160" as="sourcePoint" />
            <mxPoint x="730" y="200" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-cloudrun-subnet" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1A73E8;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="260" as="sourcePoint" />
            <mxPoint x="730" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-cloudrun-subnet-l" connectable="0" parent="e-cloudrun-subnet" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontStyle=1;" value="Direct VPC egress attach" vertex="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-subnet-psa" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#3334B9;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="750" y="470" as="sourcePoint" />
            <mxPoint x="750" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-subnet-psa-l" connectable="0" parent="e-subnet-psa" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="pg 5432 (private IP, TLS)&#xa;private-ranges-only" vertex="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-cloudrun-secretmgr-2" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DD344C;strokeWidth=2;dashed=1;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="230" as="sourcePoint" />
            <mxPoint x="230" y="700" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-cloudrun-secretmgr-2-l" connectable="0" parent="e-cloudrun-secretmgr-2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" value="Secret Manager API&#xa;(no VPC hop)" vertex="1">
          <mxGeometry relative="1" x="0.7" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
