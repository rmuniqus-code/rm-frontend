        <mxCell id="cloudrun-zone" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=12;fontStyle=1;fontColor=#1A73E8;verticalAlign=top;align=center;dashed=4;spacingTop=8;" value="Cloud Run (fully managed — no cold start, min instances = 1)" vertex="1">
          <mxGeometry height="200" width="900" x="40" y="170" as="geometry" />
        </mxCell>
        <mxCell id="cloudrun-detail" parent="cloudrun-zone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A73E8;fontColor=#1A73E8;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Cloud Run Service: rm-frontend&#xa;www.unisource.uniqus.com (managed HTTPS)&#xa;&#xa;Container: Artifact Registry rm-frontend:&lt;sha&gt;&#xa;Size: 0.5 vCPU / 1 GiB&#xa;Concurrency: 100 req/instance (matches AWS)&#xa;Auto-scale: min=1, max=4 (matches AWS)&#xa;Deploy: explicit `gcloud run deploy` per build&#xa;(Cloud Run has no ECR-style auto-deploy-on-push)" vertex="1">
          <mxGeometry height="150" width="380" x="140" y="35" as="geometry" />
        </mxCell>
        <mxCell id="nextjs-server" parent="cloudrun-zone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#147EBA;fontColor=#147EBA;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Next.js 16 (rm-frontend monorepo)&#xa;&#xa;app/page.tsx, app/(dashboard)/* (UI)&#xa;app/api/employees/route.ts&#xa;app/api/allocations/route.ts&#xa;app/api/forecast-summary/route.ts&#xa;app/api/upload/route.ts&#xa;app/api/zoho/sync/route.ts (Phase 4, not built)&#xa;… 24 API routes&#xa;lib/server/*, lib/ingestion/*&#xa;Health check: needs /healthz committed&#xa;(see GCP_INFRA_SETUP.md §7.3 note)" vertex="1">
          <mxGeometry height="150" width="350" x="540" y="35" as="geometry" />
        </mxCell>
        <mxCell id="vpc" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;strokeColor=#248814;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#248814;fontSize=12;fontStyle=1;dashed=0;" value="VPC: rm-vpc (auto-mode custom subnet) — Cloud SQL lives here, fully private" vertex="1">
          <mxGeometry height="380" width="900" x="40" y="400" as="geometry" />
        </mxCell>
        <mxCell id="subnet-app" parent="vpc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#7AA116;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=0;" value="rm-subnet-app · 10.10.0.0/24 (us-central1) — Direct VPC egress attach point" vertex="1">
          <mxGeometry height="90" width="820" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="direct-egress" parent="subnet-app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A73E8;fontSize=10;fontStyle=1;fontColor=#1A73E8;" value="Direct VPC egress&#xa;vpc-egress=private-ranges-only" vertex="1">
          <mxGeometry height="55" width="220" x="40" y="30" as="geometry" />
        </mxCell>
        <mxCell id="psa" parent="vpc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#D45B07;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=0;" value="Private Service Access range · rm-private-service-range (/24) — Cloud SQL PRIVATE IP only, no public IP" vertex="1">
          <mxGeometry height="120" width="820" x="40" y="150" as="geometry" />
        </mxCell>
        <mxCell id="cloudsql" parent="psa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3334B9;fontColor=#3334B9;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" value="Cloud SQL PostgreSQL 16&#xa;Instance: rm-db-prod&#xa;Tier: db-f1-micro (equiv. RDS db.t4g.micro)&#xa;Storage: 20 GB SSD, auto-increase&#xa;Single-zone, 7-day backups&#xa;--no-assign-ip (private only)&#xa;Deletion protection: ON" vertex="1">
          <mxGeometry height="100" width="380" x="210" y="30" as="geometry" />
        </mxCell>
        <mxCell id="no-nat-note" parent="vpc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A73E8;fontColor=#1A73E8;fontSize=10;fontStyle=1;verticalAlign=top;align=center;dashed=8;spacingTop=4;" value="No Cloud NAT / no NAT Gateway needed — Direct VPC egress reaches Cloud SQL privately while Cloud Run still reaches the public internet (Zoho, Supabase) directly. Main cost saving vs. the approved AWS NAT Gateway ($32/mo)." vertex="1">
          <mxGeometry height="40" width="820" x="40" y="290" as="geometry" />
        </mxCell>
        <mxCell id="secretmgr" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" value="Secret Manager&#xa;(equiv. Secrets Manager + SSM)&#xa;DATABASE_URL&#xa;Zoho client id/secret/refresh&#xa;Supabase url/anon/jwt&#xa;sync trigger key" vertex="1">
          <mxGeometry height="110" width="220" x="980" y="180" as="geometry" />
        </mxCell>
        <mxCell id="scheduler" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" value="Cloud Scheduler&#xa;(equiv. EventBridge Scheduler)&#xa;rm-zoho-hourly-sync&#xa;rate: 0 * * * *&#xa;POST /api/zoho/sync&#xa;x-sync-key header&#xa;— Phase 4, endpoint not built yet" vertex="1">
          <mxGeometry height="120" width="220" x="980" y="310" as="geometry" />
        </mxCell>
        <mxCell id="logging" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" value="Cloud Logging + Monitoring&#xa;(equiv. CloudWatch)&#xa;30-day retention&#xa;alerts: 5xx, latency, DB CPU,&#xa;DB storage, budget" vertex="1">
          <mxGeometry height="90" width="220" x="980" y="450" as="geometry" />
        </mxCell>
        <mxCell id="cost-box" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E6B800;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Estimated Monthly Cost: ~$40-50&#xa;(approved AWS budget: ~$60-65)&#xa;&#xa;• Cloud SQL db-f1-micro (private): ~$11-15&#xa;• Cloud Run 0.5 vCPU/1GiB, min=1: ~$18-25&#xa;• Artifact Registry + Secret Manager: ~$1-3&#xa;• Cloud Scheduler: $0 (free tier)&#xa;• Cloud Logging: ~$0-3&#xa;• Cloud NAT: $0 (not needed)&#xa;• GoDaddy uniqus.com: $0 (existing)&#xa;&#xa;See GCP_COST_PLAN.md for full breakdown." vertex="1">
          <mxGeometry height="210" width="320" x="50" y="790" as="geometry" />
        </mxCell>
        <mxCell id="security-box" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Why this is private&#xa;&#xa;• Cloud SQL has no public IP (--no-assign-ip)&#xa;• Reachable only via Private Service Access&#xa;   peering from rm-vpc&#xa;• Cloud Run reaches it over Direct VPC egress&#xa;• Public egress (Zoho, Supabase) does NOT&#xa;   route through the VPC — no NAT required" vertex="1">
          <mxGeometry height="150" width="320" x="390" y="800" as="geometry" />
        </mxCell>
        <mxCell id="dns-flow" parent="gcp-cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B2D7E;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="DNS Flow&#xa;&#xa;1. uniqus.com lives at GoDaddy (existing,&#xa;    managed by Uniqus IT) — same as AWS plan&#xa;2. Cloud Run domain mapping created for&#xa;    www.unisource.uniqus.com&#xa;3. Uniqus IT adds the returned CNAME record&#xa;4. Google provisions managed TLS cert&#xa;5. www.unisource.uniqus.com goes live" vertex="1">
          <mxGeometry height="150" width="320" x="720" y="800" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Legend" vertex="1">
          <mxGeometry height="150" width="300" x="1500" y="700" as="geometry" />
        </mxCell>
        <mxCell id="legend-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" value="➡ Solid arrow = sync HTTPS request&#xa;➡ Dashed arrow = async / scheduled job&#xa;■ Blue dashed box = Cloud Run runtime&#xa;■ Green border = VPC (Cloud SQL lives here)&#xa;■ Orange band = Private Service Access range&#xa;■ Green band = subnet with Direct VPC egress" vertex="1">
          <mxGeometry height="120" width="285" x="1507.5" y="715" as="geometry" />
        </mxCell>
        <mxCell id="deploy-flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#D45B07;fontSize=10;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" value="Deploy Flow&#xa;&#xa;1. git push main → GitLab&#xa;2. Jenkins: docker build → push to&#xa;    Artifact Registry (Workload Identity&#xa;    Federation, no static keys preferred)&#xa;3. Jenkins runs `gcloud run deploy`&#xa;    (Cloud Run has no auto-deploy-on-push)&#xa;4. Rolling deploy, old revision drained" vertex="1">
          <mxGeometry height="160" width="320" x="1150" y="700" as="geometry" />
